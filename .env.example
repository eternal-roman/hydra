# Copy to `.env` and fill in real values. Never commit `.env`.

# Kraken API (spot trading; keep withdraw disabled on the key)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Optional: WSL distro hosting kraken-cli (default: Ubuntu)
# HYDRA_WSL_DISTRO=Ubuntu

# AI providers (brain / companions)
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Dashboard auth (generate a long random string for production)
HYDRA_JWT_SECRET=

# Optional kill switches / opt-ins (see CLAUDE.md for full table)
# HYDRA_COMPANION_LIVE_EXECUTION=0
# HYDRA_FRICTION_GATE_DISABLED=0
# HYDRA_FEE_DEDUCTION_DISABLED=0
# HYDRA_QUOTE=USD
