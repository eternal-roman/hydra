# Copy to `.env` and fill in real values. Never commit `.env`.

# Kraken API (spot trading; keep withdraw disabled on the key)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Optional: WSL distro hosting kraken-cli (default: Ubuntu)
# HYDRA_WSL_DISTRO=Ubuntu

# AI providers (brain / companions)
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Dashboard auth (generate a long random string for production)
HYDRA_JWT_SECRET=

# --- Product thesis defaults (see CLAUDE.md) ---
# Live path = capital preservation rails, not growth-alpha claim.
# S3 / heartbeat = research surfaces; never place orders from these flags.

# HYDRA_QUOTE=USD
# HYDRA_HOLD_THROUGH=1          # default on; =0 raw engine (research only)
# HYDRA_TREND_OVERLAY=1         # default on; daily ensemble gate
# HYDRA_BRIDGE_TRADING=0        # default off (exit_only bridge when SOL triangle set)

# S3 daily bounce (QI always on unless disabled; shadow opt-in)
# HYDRA_S3_DISABLED=0
# HYDRA_S3_STRATEGY=0           # =1 shadow proposals to .hydra-s3/ only
# HYDRA_S3_HEARTBEAT_STATUS_DIR=heartbeat/data

# Heartbeat P(up) dashboard surface (separate `heartbeat run` process)
# HYDRA_HEARTBEAT_SURFACE=1     # =0 hides quant_indicators["heartbeat"]

# Money-safety kill switches (defaults are safe)
# HYDRA_COMPANION_LIVE_EXECUTION=0
# HYDRA_FRICTION_GATE_DISABLED=0
# HYDRA_FEE_DEDUCTION_DISABLED=0
